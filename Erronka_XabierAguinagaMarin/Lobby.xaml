<Window x:Class="Erronka_XabierAguinagaMarin.Lobby"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Erronka_XabierAguinagaMarin"
        mc:Ignorable="d"
        Title="Lobby" Height="450" Width="800" Closing="Client_Closing">
    <Grid Background="#FF314B8C">
        <Button Content="Partida hosteatu" HorizontalAlignment="Left" Margin="270,171,0,0" VerticalAlignment="Top" Click="Hosteatu_Click" FontFamily="Bahnschrift SemiBold Condensed" Name="Hosteatu" FontSize="30" Background="#FF5B65B7" BorderBrush="#FF282F65"/>
        <Button Content="Partida batera sartu" HorizontalAlignment="Left" Margin="538,171,0,0" VerticalAlignment="Top" Click="Sartu_Click" FontFamily="Bahnschrift SemiBold Condensed" x:Name="Sartu"  FontSize="30" Background="#FF5B65B7" BorderBrush="#FF282F65"/>
        <Border Margin="10,12,590,10" BorderBrush="#FF000000" BorderThickness="10" CornerRadius="10">
            <Grid Background="#FF203361" >
                <Grid HorizontalAlignment="Center" Height="158" Background="#FF1F439A" VerticalAlignment="Top" Width="180">
                    <TextBlock HorizontalAlignment="Left" Margin="0,79,0,0" TextWrapping="Wrap" Text="Ez dira kalifikazioak aurkitu" VerticalAlignment="Top" FontFamily="Bahnschrift SemiBold Condensed" FontSize="20" x:Name="puntuazioa" Width="172" Foreground="#FFFDFF00" TextAlignment="Center"/>
                    <TextBlock HorizontalAlignment="Center" Margin="0,10,0,0" TextWrapping="Wrap" Text="Batezbesteko lortutako kalifikazioa:" VerticalAlignment="Top" FontFamily="Bahnschrift SemiBold Condensed" FontSize="20" TextAlignment="Center"/>
                </Grid>
                <Grid HorizontalAlignment="Center" Height="158" Background="#FF1F439A" VerticalAlignment="Top" Width="180" Margin="0,158,0,0">
                    <TextBlock HorizontalAlignment="Left" Margin="0,79,0,0" TextWrapping="Wrap" Text="Ez dira kalifikazioak aurkitu" VerticalAlignment="Top" FontFamily="Bahnschrift SemiBold Condensed" FontSize="20" x:Name="puntuazioaEmanda" Width="172" Foreground="#FFFDFF00" TextAlignment="Center"/>
                    <TextBlock HorizontalAlignment="Center" Margin="0,10,0,0" TextWrapping="Wrap" Text="Batezbesteko emandako kalifikazioa:" VerticalAlignment="Top" FontFamily="Bahnschrift SemiBold Condensed" FontSize="20" TextAlignment="Center"/>
                </Grid>
            </Grid>
        </Border>

        <TextBox HorizontalAlignment="Left" Margin="538,251,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="206" x:Name="kodigo" FontFamily="Bahnschrift SemiBold Condensed" Height="40"/>
        <TextBlock HorizontalAlignment="Left" Margin="270,247,0,0" TextWrapping="Wrap" Text="Partida kodigoa: " VerticalAlignment="Top" FontFamily="Bahnschrift SemiBold Condensed" FontSize="20" Name="partidaCode"/>
        <Button Content="Deskargatu kalifikazioa" HorizontalAlignment="Left" Margin="260,35,0,0" VerticalAlignment="Top" Click="Deskargatu_Click" FontFamily="Bahnschrift SemiBold Condensed" x:Name="Deskargatu"  FontSize="30" Background="#FF5B65B7" BorderBrush="#FF282F65"/>

    </Grid>
</Window>
