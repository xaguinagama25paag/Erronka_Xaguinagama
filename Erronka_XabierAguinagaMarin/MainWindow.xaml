<Window x:Class="Erronka_XabierAguinagaMarin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Erronka_XabierAguinagaMarin"
        mc:Ignorable="d"
                Title="Login" Height="266" Width="308" Closing="Client_Closing">
    <Grid Background="#FF314B8C">
        <TextBlock HorizontalAlignment="Left" Margin="51,89,0,0" TextWrapping="Wrap" Text="Erabiltzailea" VerticalAlignment="Top" FontFamily="Bahnschrift SemiBold Condensed" FontSize="20"/>
        <TextBox HorizontalAlignment="Left" Margin="164,89,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120" Name="izena" FontFamily="Bahnschrift SemiBold Condensed"/>
        <TextBlock HorizontalAlignment="Center" Margin="0,36,0,0" TextWrapping="Wrap" Text="Login" VerticalAlignment="Top" FontFamily="Bahnschrift SemiBold Condensed" FontSize="20"/>
        <TextBlock HorizontalAlignment="Left" Margin="51,125,0,0" TextWrapping="Wrap" Text="Pasahitza" VerticalAlignment="Top" FontFamily="Bahnschrift SemiBold Condensed" FontSize="20"/>
        <PasswordBox HorizontalAlignment="Left" Margin="164,129,0,0" VerticalAlignment="Top" Width="120" Name="pasahitza" FontFamily="Bahnschrift SemiBold Condensed"/>
        <Button Content="Login" HorizontalAlignment="Center" Margin="0,186,0,0" VerticalAlignment="Top" Name="logeatu" FontFamily="Bahnschrift SemiBold Condensed" FontSize="20" Background="#FF5B65B7" BorderBrush="#FF282F65" Click="Logeatu_Click"/>
        <TextBlock HorizontalAlignment="Left" Margin="9,7,0,0" TextWrapping="Wrap" Text="Estatus: -" VerticalAlignment="Top" FontFamily="Bahnschrift SemiBold Condensed" FontSize="20" Name="status" Width="163"/>
        <Button Content="Saiatu berriro konektatzen" HorizontalAlignment="Left" Margin="172,9,0,0" VerticalAlignment="Top" x:Name="berriro" FontFamily="Bahnschrift SemiBold Condensed" FontSize="15" Background="#FF5B65B7" BorderBrush="#FF282F65" Click="SaiatuBerriro" Height="21" Width="136" Visibility="Collapsed"/>
        <Button Content="Erregistratu" HorizontalAlignment="Left" Margin="10,212,0,0" VerticalAlignment="Top" x:Name="erregistratu" FontFamily="Bahnschrift SemiBold Condensed" FontSize="20" Background="#FF5B65B7" BorderBrush="#FF282F65" Click="Erregistratu_Click"/>

    </Grid>
</Window>
